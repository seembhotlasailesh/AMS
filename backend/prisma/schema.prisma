generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  action     String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model admin_college_permissions {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String   @db.Uuid
  college_id               String   @db.Uuid
  can_manage_colleges      Boolean  @default(false)
  can_manage_departments   Boolean  @default(false)
  can_manage_faculty       Boolean  @default(false)
  can_manage_students      Boolean  @default(false)
  can_manage_reports       Boolean  @default(false)
  can_manage_notifications Boolean  @default(false)
  can_manage_settings      Boolean  @default(false)
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
  colleges                 colleges @relation(fields: [college_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                    users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, college_id])
  @@index([college_id], map: "idx_admin_college_permissions_college")
  @@index([user_id], map: "idx_admin_college_permissions_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id  String   @db.Uuid
  subject_id  String   @db.Uuid
  class_id    String   @db.Uuid
  date        DateTime @db.Date
  hour_number Int
  status      String
  marked_by   String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  classes     classes  @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users    @relation(fields: [marked_by], references: [id], onUpdate: NoAction)
  students    students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects    subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([student_id, subject_id, class_id, date, hour_number])
  @@index([class_id, date], map: "idx_attendance_class_date")
  @@index([student_id], map: "idx_attendance_student")
}

model class_students {
  class_id   String   @db.Uuid
  student_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  classes    classes  @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([class_id, student_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model classes {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  class_name     String
  section        String           @default("A")
  department_id  String           @db.Uuid
  faculty_id     String           @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  attendance     attendance[]
  class_students class_students[]
  departments    departments      @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty        faculty          @relation(fields: [faculty_id], references: [id], onUpdate: NoAction)
  exams          exams[]
  subjects       subjects[]

  @@unique([department_id, section])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model college_settings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  college_id          String   @unique @db.Uuid
  required_attendance Int      @default(75)
  email_enabled       Boolean  @default(true)
  sms_enabled         Boolean  @default(false)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)
  colleges            colleges @relation(fields: [college_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([college_id], map: "idx_college_settings_college")
}

model colleges {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  college_name              String
  address                   String
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  is_active                 Boolean                     @default(true)
  admin_college_permissions admin_college_permissions[]
  college_settings          college_settings?
  departments               departments[]
}

model departments {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_name String
  college_id      String     @db.Uuid
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  classes         classes[]
  colleges        colleges   @relation(fields: [college_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty         faculty[]
  students        students[]

  @@unique([department_name, college_id])
}

model faculty {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String      @unique @db.Uuid
  department_id String      @db.Uuid
  designation   String
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  employee_id   String?
  classes       classes[]
  exams         exams[]
  departments   departments @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects      subjects[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model leave_requests {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id String   @db.Uuid
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  reason     String
  status     String   @default("pending")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  students   students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([student_id], map: "idx_leave_requests_student")
}

model notifications {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  message      String
  recipient_id String   @db.Uuid
  sender_id    String?  @db.Uuid
  is_read      Boolean  @default(false)
  type         String   @default("info")
  priority     String   @default("normal")
  category     String   @default("general")
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [recipient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([recipient_id], map: "idx_notifications_recipient")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model students {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String           @unique @db.Uuid
  department_id  String           @db.Uuid
  roll_number    String           @unique
  batch_year     Int
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  attendance     attendance[]
  class_students class_students[]
  leave_requests leave_requests[]
  marks          marks[]
  departments    departments      @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model subjects {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_name String
  class_id     String       @db.Uuid
  faculty_id   String       @db.Uuid
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  attendance   attendance[]
  exams        exams[]
  classes      classes      @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty      faculty      @relation(fields: [faculty_id], references: [id], onUpdate: NoAction)

  @@unique([subject_name, class_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String
  email                     String                      @unique
  password                  String
  role                      String
  phone                     String
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  activity_logs             activity_logs[]
  admin_college_permissions admin_college_permissions[]
  attendance                attendance[]
  faculty                   faculty?
  notifications             notifications[]
  profile_update_requests   profile_update_requests[]
  reviewed_profile_update_requests profile_update_requests[] @relation("profile_update_request_reviewer")
  students                  students?
}

model profile_update_requests {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  requested_data Json
  status         String    @default("pending")
  reviewed_by    String?   @db.Uuid
  reviewed_at    DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviewer       users?    @relation("profile_update_request_reviewer", fields: [reviewed_by], references: [id], onUpdate: NoAction)

  @@index([user_id], map: "idx_profile_update_requests_user")
  @@index([status], map: "idx_profile_update_requests_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model exams {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  class_id    String    @db.Uuid
  subject_id  String    @db.Uuid
  faculty_id  String    @db.Uuid
  exam_name   String
  exam_type   String
  semester    Int?
  total_marks Int
  exam_date   DateTime? @db.Date
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  classes     classes   @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty     faculty   @relation(fields: [faculty_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects    subjects  @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  marks       marks[]

  @@unique([class_id, subject_id, exam_name, exam_type])
  @@index([class_id, subject_id], map: "idx_exams_class_subject")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model marks {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exam_id        String   @db.Uuid
  student_id     String   @db.Uuid
  marks_obtained Decimal  @db.Decimal(6, 2)
  remarks        String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  exams          exams    @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students       students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([exam_id, student_id])
  @@index([student_id], map: "idx_marks_student")
}
